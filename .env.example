# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Discord OAuth — https://discord.com/developers/applications
# Redirect URI: {origin}/auth/callback/discord  (e.g. http://localhost:5173/auth/callback/discord)
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Path of Exile OAuth — request a confidential client (authorization_code + account:profile)
# via oauth@grindinggear.com. Redirect URI: {origin}/auth/callback/poe
AUTH_POE_ID=
AUTH_POE_SECRET=

# Until at least one provider above is set, forecasting runs in guest mode.
